<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Player Profile</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#050505;
color:white;
padding:20px;
}

.back-btn{
display:inline-flex;
align-items:center;
gap:10px;
margin-bottom:25px;
color:#888;
text-decoration:none;
font-size:15px;
}

.profile-card{
background:#111;
border-radius:32px;
padding:30px;
max-width:700px;
margin:auto;
border:1px solid rgba(255,255,255,0.05);
}

.top-profile{
display:flex;
align-items:center;
gap:20px;
flex-wrap:wrap;
}

.profile-pic{
width:100px;
height:100px;
border-radius:24px;
background:#222;
display:flex;
align-items:center;
justify-content:center;
font-size:32px;
font-weight:bold;
}

.big-name{
font-size:46px;
font-weight:bold;
}

.player-rank{
margin-top:10px;
display:inline-block;
background:#2a2a2a;
padding:8px 16px;
border-radius:18px;
color:#d8ab6d;
font-size:14px;
}

.tags{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-top:25px;
}

.tag{
background:#171717;
padding:10px 15px;
border-radius:18px;
font-size:13px;
color:#aaa;
display:flex;
align-items:center;
gap:8px;
}

.main-stats{
display:flex;
gap:15px;
margin-top:30px;
}

.big-stat-card{
flex:1;
background:#0c0c0c;
padding:24px;
border-radius:24px;
}

.stat-title{
color:#777;
font-size:13px;
}

.big-number{
font-size:42px;
font-weight:bold;
margin-top:8px;
}

.small-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;
margin-top:30px;
}

.small-card{
background:#0c0c0c;
padding:24px;
border-radius:24px;
}

.small-title{
color:#777;
font-size:13px;
}

.small-number{
font-size:42px;
font-weight:bold;
margin-top:8px;
}

@media(max-width:768px){

.big-name{
font-size:34px;
}

.main-stats{
flex-direction:column;
}

.small-grid{
grid-template-columns:1fr;
}

}

</style>

</head>

<body>

<a href="index.html"
class="back-btn">

<i class="fa-solid fa-arrow-left"></i>
Back

</a>

<div class="profile-card">

<div class="top-profile">

<div class="profile-pic"
id="profilePic">
</div>

<div>

<div class="big-name"
id="playerName">
</div>

<div class="player-rank">
Bronze I
</div>

</div>

</div>

<div class="tags">

<div class="tag">
<i class="fa-solid fa-futbol"></i>
Player
</div>

<div class="tag">
<i class="fa-solid fa-earth-americas"></i>
NA
</div>

<div class="tag">
<i class="fa-solid fa-trophy"></i>
RPSG
</div>

</div>

<div class="main-stats">

<div class="big-stat-card">

<div class="stat-title">
POINTS
</div>

<div class="big-number">
0
</div>

</div>

<div class="big-stat-card">

<div class="stat-title">
MARKET VALUE
</div>

<div class="big-number">
£0
</div>

</div>

</div>

<div class="small-grid">

<div class="small-card">

<div class="small-title">
GOALS
</div>

<div class="small-number">
0
</div>

</div>

<div class="small-card">

<div class="small-title">
ASSISTS
</div>

<div class="small-number">
0
</div>

</div>

<div class="small-card">

<div class="small-title">
BLOCKS
</div>

<div class="small-number">
0
</div>

</div>

<div class="small-card">

<div class="small-title">
CLEAN SHEETS
</div>

<div class="small-number">
0
</div>

</div>

</div>

</div>

<script>

const params =
new URLSearchParams(window.location.search);

const player =
params.get("name");

document.getElementById("playerName")
.innerText = player;

document.getElementById("profilePic")
.innerText =
player.substring(0,2).toUpperCase();

</script>

</body>
</html>
